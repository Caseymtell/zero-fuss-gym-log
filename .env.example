# Copy this file to .env.local and fill in your Supabase values.
# .env.local is gitignored — it never gets committed.
#
# For the deployed app, the same two values need to be set as GitHub Actions
# secrets in: Settings → Secrets and variables → Actions

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
